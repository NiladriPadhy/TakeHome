<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp.MainPage"
             Title="Vitals Monitor">
    <VerticalStackLayout Padding="10" Spacing="10">
        <HorizontalStackLayout Spacing="10">
            <Button Text="Refresh"
                    Command="{Binding RefreshCommand}"
                    WidthRequest="100"
                    HeightRequest="40" />
            <Label Text="{Binding StatusMessage}"
                   VerticalOptions="Center"
                   FontAttributes="Bold" />
        </HorizontalStackLayout>

        <CollectionView ItemsSource="{Binding Measurements}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="5" ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <Label Text="{Binding DeviceId}" Grid.Column="0" />
                        <Label Text="{Binding Type}" Grid.Column="1" />
                        <Label Text="{Binding Value}" Grid.Column="2" />
                        <Label Text="{Binding Timestamp, StringFormat='{0:T}'}" Grid.Column="3" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
